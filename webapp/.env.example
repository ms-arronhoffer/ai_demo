# Environment configuration for the live Agentic Playground.
#
# Copy this file to `.env.local` and fill in the values:
#
#   cp .env.example .env.local
#
# The live LLM-backed features (Microsoft Entra sign-in + the Azure OpenAI
# agent) are only enabled when the relevant variables are set. When they are
# absent, the app still builds and runs — the live features simply report that
# they are unavailable. Never commit real secrets; `.env*` files are gitignored.

# ── Auth.js (next-auth v5) ────────────────────────────────────────────────────
# A random secret used to encrypt session tokens. Generate one with:
#   openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET=

# ── Microsoft Entra ID (Azure AD) sign-in ────────────────────────────────────
# App-registration credentials for the Entra provider. Register a redirect URI
# of `https://<your-host>/api/auth/callback/microsoft-entra-id`.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Issuer / tenant URL, e.g. https://login.microsoftonline.com/<tenant-id>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# ── Authorization allowlist ──────────────────────────────────────────────────
# Comma-separated Entra identities (email/UPN or object id) permitted to use
# the live LLM features. Evaluated case-insensitively. Fail-closed: if empty,
# nobody is approved.
ALLOWED_USERS=

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# Backend for the live, LLM-driven interactive features. Requests authenticate
# with Microsoft Entra ID — no API key is used, so the target resource should
# have local (key) auth disabled. Grant the app's Azure **managed identity** the
# "Cognitive Services OpenAI User" role on the Azure OpenAI resource.
#
# - System-assigned managed identity: leave AZURE_MANAGED_IDENTITY_CLIENT_ID
#   empty; DefaultAzureCredential picks up the host identity automatically.
# - User-assigned managed identity: set AZURE_MANAGED_IDENTITY_CLIENT_ID to its
#   client id.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
# Optional; defaults to 2024-10-21 when unset.
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional; client id of a user-assigned managed identity to authenticate with.
AZURE_MANAGED_IDENTITY_CLIENT_ID=
